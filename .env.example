PORT=3000

# Chat platform: telegram or whatsapp
BOT_PLATFORM=telegram

# Telegram Bot API
# Create this token with @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Meta WhatsApp Cloud API
# Optional. Only needed when BOT_PLATFORM=whatsapp.
META_VERIFY_TOKEN=make-a-long-random-token
META_ACCESS_TOKEN=your-meta-system-user-access-token
META_APP_SECRET=optional-meta-app-secret-for-webhook-signature-checks
META_GRAPH_VERSION=v25.0

# AI provider: openrouter, huggingface, groq, openai, or custom
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Telegram Agent

# Hugging Face Inference Providers
# Create a token with "Make calls to Inference Providers" permission.
HF_TOKEN=your-hugging-face-token
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:fireworks-ai

# Groq, optional. Fast hosted open-source models; check current free/paid quota.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI, optional.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini

# Custom OpenAI-compatible provider, optional.
AI_API_KEY=your-custom-provider-key
AI_BASE_URL=https://example.com/v1
AI_MODEL=provider-model-name

# Agent behavior
AGENT_NAME=Telegram Agent
AGENT_INSTRUCTIONS=You are a helpful, concise Telegram assistant. Answer clearly, ask one follow-up question when needed, and never claim to have completed real-world actions unless a tool actually did them.
MAX_HISTORY_MESSAGES=12
